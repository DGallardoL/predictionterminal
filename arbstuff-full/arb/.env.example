# =============================================================================
# arb/ backend - environment template
# =============================================================================
# Copy this file to `.env` and fill in your own values if you want any of the
# OPTIONAL features (account-aware sizing, email/Telegram alerts, etc.).
#
# *** NOTHING in this file is required just to DETECT arbs. ***
# The detection engine fetches public Kalshi + Polymarket orderbooks and
# writes results to dashboard_state.json with zero credentials.
#
# Leave any block empty to disable that feature.
# =============================================================================

# --- Kalshi (OPTIONAL: only needed for balance fetch / order placement) ---
# Public orderbook reads work without these.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Polymarket (OPTIONAL: only needed for balance fetch / order placement) ---
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=
POLY_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_SIGNATURE_TYPE=1
POLYMARKET_PROXY_ADDRESS=

# --- Gmail alerts (OPTIONAL) ---
# Use a Google app password, NOT your main account password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_RECIPIENT=

# --- Telegram alerts (OPTIONAL) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Twilio / WhatsApp alerts (OPTIONAL) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_WHATSAPP=
TWILIO_TO_WHATSAPP=
TWILIO_TEMPLATE_SID=
