          "legendFormat": "p95 latency — {{source}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum by (source) (rate(pfm_factor_history_fetches_total{source=~\"$source\", status=\"error\"}[5m]))",
          "legendFormat": "errors/s — {{source}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Upstream API health — Polymarket / Kalshi / Manifold / PredictIt",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
