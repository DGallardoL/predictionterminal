# Backend
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
LOG_LEVEL=INFO

# Polymarket
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Security (override in production)
# PFM_CORS_ORIGINS — comma-separated list of allowed origins for the FastAPI
# CORS middleware. The dev default below covers the split-port local layout
# (UI on :8080, API on :8000). Set to your exact deploy origin(s) in prod.
# Legacy CORS_ORIGINS is still honoured as a fallback for older compose files.
PFM_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
# Toggle the X-Frame-Options / X-Content-Type-Options / Referrer-Policy
# response headers. Default ON. Set to 0 only if you need to disable them
# for a specific test rig — production should always leave this enabled.
PFM_SECURITY_HEADERS_ENABLED=1

# Alerts (optional)
PFM_ALERTS_DRY_RUN=1
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Observability (optional)
SENTRY_DSN=
# Prometheus /metrics endpoint. Default OFF so the surface is opt-in. When
# enabled and PFM_METRICS_TOKEN is non-empty, callers must send
# ``Authorization: Bearer <token>`` to access /metrics; an empty token leaves
# the endpoint open (intended for trusted internal-network deployments).
PFM_METRICS_ENABLED=0
PFM_METRICS_TOKEN=

# Cross-venue arb engine autostart. The engine is launched as a subprocess
# from the FastAPI lifespan; SETNX leader-election on PFM_ARB_ENGINE_LEADER_TTL_S
# (default 60s) ensures exactly one gunicorn worker spawns it. Lock value is
# a per-process token and the refresh tick uses a Lua CAS so a successor
# can't accidentally extend our lease.
PFM_ARB_ENGINE_AUTOSTART=0
PFM_ARB_ENGINE_MODE=og
PFM_ARB_ENGINE_LEADER_TTL_S=60
